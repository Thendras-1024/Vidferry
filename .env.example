YOUTUBE_DOWNLOAD_DIR=./videos/youtube
YOUTUBE_PROCESSED_DIR=./videos/processed

# Optional: yt-dlp JavaScript runtime. Leave empty to auto-detect deno first, then node.
# Example:
# YTDLP_JS_RUNTIME=node
# YTDLP_JS_RUNTIME_PATH=C:/nvm4w/nodejs/node.exe
# Optional: allow yt-dlp to fetch external challenge solver components when YouTube requires them.
# YTDLP_REMOTE_COMPONENTS=ejs:github

# Optional: OpenAI-compatible LLM endpoint for content analysis / editing plan.
# DashScope example:
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_API_KEY=sk-your-dashscope-key
# LLM_MODEL=qwen-plus
# LLM_TIMEOUT=90
# LLM_MAX_TRANSCRIPT_CHARS=28000
